{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": false,
    "noEmit": true,
    "skipLibCheck": true,
    "types": ["vitest/globals", "node", "express"]
  },
  "include": ["src/**/*", "tests/**/*"]
}
